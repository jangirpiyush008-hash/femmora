<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ shop.name }}</title>
    {{ content_for_header }}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    <style>
      :root {
        --color-bg: {{ settings.color_bg }};
        --color-text: {{ settings.color_text }};
        --color-brand: {{ settings.color_brand }};
        --color-brand-contrast: {{ settings.color_brand_contrast }};
        --color-muted: {{ settings.color_muted }};
        --font-heading: {{ settings.type_header_font.family | default: 'Playfair Display' }}, Georgia, serif;
        --font-body: {{ settings.type_body_font.family | default: 'Nunito Sans' }}, sans-serif;
        --radius-btn: {{ settings.button_radius }}px;
        --radius-card: {{ settings.card_radius }}px;
        --page-width: 1200px;
      }
    </style>
  </head>
  <body>
    <div style="min-height:100vh;display:grid;place-items:center;text-align:center;padding:24px;background:var(--color-bg)">
      <div style="max-width:440px">
        <h1 style="color:var(--color-brand)">{{ settings.brand_name | default: shop.name }}</h1>
        <p style="opacity:.75">{{ shop.password_message | default: 'Opening soon. Sign up to be the first to shop.' }}</p>
        {%- form 'storefront_password' -%}
          {{ form.errors | default_errors }}
          <div style="display:flex;gap:8px;margin-top:16px">
            <input class="input" type="password" name="password" placeholder="Store password" style="flex:1">
            <button type="submit" class="btn btn--primary">Enter</button>
          </div>
        {%- endform -%}
      </div>
    </div>
    {{ content_for_layout }}
  </body>
</html>
