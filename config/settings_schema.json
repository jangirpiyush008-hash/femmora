[
  {
    "name": "theme_info",
    "theme_name": "Femorra",
    "theme_version": "1.0.0",
    "theme_author": "Custom",
    "theme_documentation_url": "https://shopify.dev/themes",
    "theme_support_url": "https://shopify.dev/themes"
  },
  {
    "name": "Logo",
    "settings": [
      { "type": "text", "id": "brand_name", "label": "Brand name (text logo)", "default": "Femorra" },
      { "type": "image_picker", "id": "logo", "label": "Logo image" },
      { "type": "range", "id": "logo_width", "min": 60, "max": 250, "step": 10, "unit": "px", "label": "Logo width", "default": 140 },
      { "type": "image_picker", "id": "favicon", "label": "Favicon (32 x 32px)" }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "color", "id": "color_bg", "label": "Page background", "default": "#FDF4F1" },
      { "type": "color", "id": "color_text", "label": "Body text", "default": "#2B2724" },
      { "type": "color", "id": "color_brand", "label": "Primary / brand", "default": "#A64D5F" },
      { "type": "color", "id": "color_brand_contrast", "label": "Text on brand", "default": "#FFFFFF" },
      { "type": "color", "id": "color_link", "label": "Links", "default": "#A64D5F" },
      { "type": "color", "id": "color_link_hover", "label": "Link hover / sale", "default": "#C0607A" },
      { "type": "color", "id": "color_accent_gold", "label": "Jewellery accent (gold)", "default": "#C6A15B" },
      { "type": "color", "id": "color_accent_sage", "label": "Mom accent (sage)", "default": "#A9B9A3" },
      { "type": "color", "id": "color_muted", "label": "Borders / dividers", "default": "#EFDEDA" }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      { "type": "font_picker", "id": "type_header_font", "label": "Heading font", "default": "playfair_display_n4" },
      { "type": "font_picker", "id": "type_body_font", "label": "Body font", "default": "nunito_sans_n4" }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      { "type": "range", "id": "page_width", "min": 1000, "max": 1440, "step": 40, "unit": "px", "label": "Max content width", "default": 1200 },
      { "type": "range", "id": "section_padding", "min": 32, "max": 96, "step": 8, "unit": "px", "label": "Section vertical padding (desktop)", "default": 56 },
      { "type": "range", "id": "card_radius", "min": 0, "max": 20, "step": 2, "unit": "px", "label": "Card corner radius", "default": 8 }
    ]
  },
  {
    "name": "Buttons",
    "settings": [
      { "type": "range", "id": "button_radius", "min": 0, "max": 40, "step": 2, "unit": "px", "label": "Button corner radius", "default": 8 }
    ]
  },
  {
    "name": "Product cards",
    "settings": [
      { "type": "checkbox", "id": "card_show_vendor", "label": "Show vendor", "default": false },
      { "type": "checkbox", "id": "card_show_sale_badge", "label": "Show sale badge", "default": true }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select", "id": "cart_type", "label": "Cart type", "default": "drawer",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ]
      },
      { "type": "checkbox", "id": "show_shipping_bar", "label": "Show free-shipping progress bar", "default": true },
      { "type": "text", "id": "free_shipping_threshold", "label": "Free shipping threshold (₹, number only)", "default": "999" },
      { "type": "text", "id": "prepaid_note", "label": "Prepaid nudge message", "default": "Prepaid orders get priority dispatch" },
      { "type": "checkbox", "id": "show_gst_note", "label": "Show \"Inclusive of all taxes\" under prices", "default": true }
    ]
  },
  {
    "name": "Social & footer",
    "settings": [
      { "type": "text", "id": "social_instagram", "label": "Instagram URL" },
      { "type": "text", "id": "social_facebook", "label": "Facebook URL" },
      { "type": "text", "id": "social_whatsapp", "label": "WhatsApp URL" },
      { "type": "text", "id": "social_youtube", "label": "YouTube URL" }
    ]
  }
]
