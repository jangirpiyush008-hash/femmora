<section class="section">
  <div class="page-width page-narrow">
    <div style="text-align:center;margin-bottom:24px">
      <small style="opacity:.6">{{ article.published_at | date: '%b %d, %Y' }}</small>
      <h1>{{ article.title }}</h1>
    </div>
    {%- if article.image -%}
      <img src="{{ article.image | image_url: width: 1400 }}" alt="{{ article.title | escape }}" style="border-radius:var(--radius-card);margin-bottom:24px">
    {%- endif -%}
    <div class="rte">{{ article.content }}</div>
  </div>
</section>

{% schema %}
{ "name": "Article", "settings": [] }
{% endschema %}
