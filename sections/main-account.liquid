<section class="section">
  <div class="page-width" style="max-width:860px">
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px">
      <h1 style="margin:0">Hello, {{ customer.first_name | default: 'there' }}</h1>
      <span>
        <a href="{{ routes.account_addresses_url }}">Addresses</a> &middot;
        <a href="{{ routes.account_logout_url }}">{{ 'customer.logout' | t }}</a>
      </span>
    </div>

    <h3 style="margin-top:32px">Order history</h3>
    {%- if customer.orders.size > 0 -%}
      <table class="size-table" style="text-align:left">
        <thead><tr><th>Order</th><th>Date</th><th>Total</th><th>Status</th></tr></thead>
        <tbody>
          {%- for order in customer.orders -%}
            <tr>
              <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
              <td>{{ order.created_at | date: '%b %d, %Y' }}</td>
              <td>{{ order.total_price | money }}</td>
              <td>{{ order.fulfillment_status_label }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    {%- else -%}
      <p style="opacity:.65">You haven't placed any orders yet.</p>
      <a class="btn btn--primary" href="{{ routes.all_products_collection_url }}">{{ 'general.continue_shopping' | t }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Account", "settings": [] }
{% endschema %}
