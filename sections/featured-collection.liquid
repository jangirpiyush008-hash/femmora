<section class="section">
  <div class="page-width">
    <div class="section-head">
      <h2>{{ section.settings.heading }}</h2>
      {%- assign coll = collections[section.settings.collection] -%}
      {%- if coll != blank -%}
        <a class="all-link" href="{{ coll.url }}">{{ section.settings.view_all_label }}</a>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- if coll.products.size > 0 -%}
        {%- for product in coll.products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- liquid
          assign dnames = "Cotton Feeding Kurti;Maternity A-line Dress;Nursing Bra — Pack of 3;Kurta Set with Dupatta;Silver Oxidised Earrings;Soft Maternity Nightwear;Straight Cotton Kurti;Silver Necklace Set" | split: ";"
          assign dprices = "799;1199;699;1499;499;899;649;1299" | split: ";"
          assign dcompare = "1499;1999;999;2499;899;1499;1199;2199" | split: ";"
        -%}
        {%- for i in (1..section.settings.products_to_show) -%}
          {%- assign idx = forloop.index0 | modulo: 8 -%}
          <div class="pcard">
            <a class="pcard__media" href="{{ routes.all_products_collection_url }}">
              <span class="pcard__badge">Sample</span>
              {{ 'product-apparel-3' | placeholder_svg_tag }}
            </a>
            <div>
              <h3 class="pcard__title">{{ dnames[idx] }}</h3>
              <span class="price price--sale"><span class="price__current">₹{{ dprices[idx] }}</span><span class="price__compare">₹{{ dcompare[idx] }}</span></span>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured products" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "label": "Products to show", "default": 4 },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View all" }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
