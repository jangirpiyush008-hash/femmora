<section class="slideshow" data-slideshow data-autoplay="{{ section.settings.autoplay }}" data-interval="{{ section.settings.interval | times: 1000 }}" aria-roledescription="carousel" aria-label="{{ section.settings.aria | default: 'Promotions' }}">
  <div class="slides" data-slides>
    {%- for block in section.blocks -%}
      <div class="slide{% if forloop.first %} is-active{% endif %}" data-slide {{ block.shopify_attributes }} aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}">
        {%- if block.settings.image != blank -%}
          <img class="slide__img" src="{{ block.settings.image | image_url: width: 2200 }}"
               srcset="{{ block.settings.image | image_url: width: 900 }} 900w, {{ block.settings.image | image_url: width: 1600 }} 1600w, {{ block.settings.image | image_url: width: 2200 }} 2200w"
               sizes="100vw" alt="{{ block.settings.heading | escape }}"
               width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}"
               loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
        {%- else -%}
          <div class="slide__ph" style="--i: {{ forloop.index0 }}"></div>
        {%- endif -%}
        <div class="slide__overlay" style="opacity: {{ block.settings.overlay | divided_by: 100.0 }}"></div>
        {%- if block.settings.link != blank -%}
          <a class="slide__link" href="{{ block.settings.link }}" aria-label="{{ block.settings.button_label | default: block.settings.heading | default: 'Shop' | escape }}"></a>
        {%- endif -%}
        {%- if block.settings.heading != blank or block.settings.button_label != blank -%}
        <div class="slide__content page-width" style="text-align: {{ block.settings.align }}">
          {%- if block.settings.eyebrow != blank -%}<span class="slide__eyebrow">{{ block.settings.eyebrow }}</span>{%- endif -%}
          {%- if block.settings.heading != blank -%}<h2 class="slide__title">{{ block.settings.heading }}</h2>{%- endif -%}
          {%- if block.settings.subtext != blank -%}<p class="slide__text">{{ block.settings.subtext }}</p>{%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.link | default: routes.all_products_collection_url }}" class="btn btn--primary" style="position:relative;z-index:3">{{ block.settings.button_label }}</a>
          {%- endif -%}
        </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <button class="slideshow__arrow slideshow__arrow--prev" data-prev aria-label="Previous slide">‹</button>
    <button class="slideshow__arrow slideshow__arrow--next" data-next aria-label="Next slide">›</button>
    <div class="slideshow__dots" data-dots>
      {%- for block in section.blocks -%}
        <button class="slideshow__dot{% if forloop.first %} is-active{% endif %}" data-dot="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

<script>
  (function () {
    var root = document.currentScript.previousElementSibling;
    if (!root || !root.matches('[data-slideshow]')) { root = document.querySelector('[data-slideshow]'); }
    if (!root) return;
    var slides = [].slice.call(root.querySelectorAll('[data-slide]'));
    if (slides.length < 2) return;
    var dots = [].slice.call(root.querySelectorAll('[data-dot]'));
    var i = 0, timer = null;
    var auto = root.getAttribute('data-autoplay') === 'true';
    var interval = parseInt(root.getAttribute('data-interval'), 10) || 5000;
    function go(n) {
      slides[i].classList.remove('is-active'); slides[i].setAttribute('aria-hidden', 'true');
      if (dots[i]) dots[i].classList.remove('is-active');
      i = (n + slides.length) % slides.length;
      slides[i].classList.add('is-active'); slides[i].setAttribute('aria-hidden', 'false');
      if (dots[i]) dots[i].classList.add('is-active');
    }
    function next() { go(i + 1); }
    function prev() { go(i - 1); }
    function start() { if (auto) { stop(); timer = setInterval(next, interval); } }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }
    var nx = root.querySelector('[data-next]'), pv = root.querySelector('[data-prev]');
    if (nx) nx.addEventListener('click', function () { next(); start(); });
    if (pv) pv.addEventListener('click', function () { prev(); start(); });
    dots.forEach(function (d) { d.addEventListener('click', function () { go(parseInt(d.getAttribute('data-dot'), 10)); start(); }); });
    root.addEventListener('mouseenter', stop); root.addEventListener('mouseleave', start);
    start();
  })();
</script>

{% schema %}
{
  "name": "Slideshow",
  "settings": [
    { "type": "checkbox", "id": "autoplay", "label": "Auto-rotate slides", "default": true },
    { "type": "range", "id": "interval", "min": 3, "max": 10, "step": 1, "unit": "s", "label": "Change slide every", "default": 5 }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "range", "id": "overlay", "min": 0, "max": 70, "step": 5, "unit": "%", "label": "Image darken", "default": 25 },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "New arrivals" },
        { "type": "textarea", "id": "subtext", "label": "Subtext" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
        { "type": "url", "id": "link", "label": "Button link" },
        {
          "type": "select", "id": "align", "label": "Text alignment", "default": "center",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ]
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Slideshow",
      "blocks": [
        { "type": "slide", "settings": { "eyebrow": "Femorra", "heading": "New arrivals", "subtext": "Maternity & feeding wear, ethnic kurtis and silver jewellery — made for you.", "button_label": "Shop now" } },
        { "type": "slide", "settings": { "eyebrow": "For every mom", "heading": "Comfort meets style", "subtext": "Feeding-friendly kurtis, dresses and nursing bras designed for real life.", "button_label": "Shop Mom" } },
        { "type": "slide", "settings": { "eyebrow": "Finishing touch", "heading": "Silver jewellery", "subtext": "Everyday elegance that pairs with everything.", "button_label": "Shop Jewellery" } }
      ]
    }
  ]
}
{% endschema %}
