<section class="section">
  <div class="page-width">
    {%- paginate collection.products by section.settings.per_page -%}

      <div class="coll-toolbar">
        <button type="button" class="btn btn--outline filters-toggle">Filters</button>
        <span class="coll-toolbar__count">{{ collection.products_count }} products</span>
        <label class="visually-hidden" for="SortBy">Sort by</label>
        <select id="SortBy" class="input" style="width:auto" data-sort-by>
          {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
          {%- for option in collection.sort_options -%}
            <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>{{ option.name }}</option>
          {%- endfor -%}
        </select>
      </div>

      <div class="coll-layout">
        <aside class="filters">
          {%- if collection.filters.size > 0 -%}
            <form>
              {%- for filter in collection.filters -%}
                <details open>
                  <summary>{{ filter.label }}</summary>
                  {%- case filter.type -%}
                    {%- when 'boolean', 'list' -%}
                      {%- for value in filter.values -%}
                        <label>
                          <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}"
                                 {% if value.active %}checked{% endif %} onchange="this.form.submit()">
                          {{ value.label }} ({{ value.count }})
                        </label>
                      {%- endfor -%}
                    {%- when 'price_range' -%}
                      <div class="price-inputs">
                        <input class="input" type="number" name="{{ filter.min_value.param_name }}"
                               placeholder="Min ₹" min="0"
                               value="{% if filter.min_value.value %}{{ filter.min_value.value | money_without_currency | remove: ',' }}{% endif %}">
                        <input class="input" type="number" name="{{ filter.max_value.param_name }}"
                               placeholder="Max ₹" min="0"
                               value="{% if filter.max_value.value %}{{ filter.max_value.value | money_without_currency | remove: ',' }}{% endif %}">
                      </div>
                      <button type="submit" class="btn btn--outline" style="margin-top:10px;min-height:40px">Apply</button>
                  {%- endcase -%}
                </details>
              {%- endfor -%}
            </form>
          {%- else -%}
            <p style="font-size:.82rem;opacity:.6">Filters appear when products are added. Enable size/price filters via the free Search &amp; Discovery app.</p>
          {%- endif -%}
        </aside>

        <div>
          {%- if collection.products.size > 0 -%}
            <div class="product-grid">
              {%- for product in collection.products -%}
                {% render 'product-card', product: product %}
              {%- endfor -%}
            </div>
            {%- if paginate.pages > 1 -%}
              <nav class="pagination" aria-label="Pagination">
                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <a href="{{ part.url }}">{{ part.title }}</a>
                  {%- else -%}
                    <span class="{% if part.title == paginate.current_page %}current{% endif %}">{{ part.title }}</span>
                  {%- endif -%}
                {%- endfor -%}
              </nav>
            {%- endif -%}
          {%- else -%}
            {%- liquid
              assign dnames = "Cotton Feeding Kurti;Maternity A-line Dress;Nursing Bra — Pack of 3;Kurta Set with Dupatta;Silver Oxidised Earrings;Soft Maternity Nightwear;Straight Cotton Kurti;Silver Necklace Set" | split: ";"
              assign dprices = "799;1199;699;1499;499;899;649;1299" | split: ";"
              assign dcompare = "1499;1999;999;2499;899;1499;1199;2199" | split: ";"
            -%}
            <div class="product-grid">
              {%- for i in (1..8) -%}
                {%- assign idx = forloop.index0 | modulo: 8 -%}
                <div class="pcard">
                  <a class="pcard__media" href="{{ routes.all_products_collection_url }}"><span class="pcard__badge">Sample</span>{{ 'product-apparel-3' | placeholder_svg_tag }}</a>
                  <div><h3 class="pcard__title">{{ dnames[idx] }}</h3><span class="price price--sale"><span class="price__current">₹{{ dprices[idx] }}</span><span class="price__compare">₹{{ dcompare[idx] }}</span></span></div>
                </div>
              {%- endfor -%}
            </div>
            <p style="text-align:center;opacity:.6;margin-top:20px;font-size:.85rem">Sample products — your real items appear here automatically once added.</p>
          {%- endif -%}
        </div>
      </div>

    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection grid",
  "settings": [
    { "type": "range", "id": "per_page", "min": 8, "max": 48, "step": 4, "label": "Products per page", "default": 24 }
  ]
}
{% endschema %}
