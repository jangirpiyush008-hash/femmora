<section class="section">
  <div class="page-width" style="max-width:760px">
    <h1 style="text-align:center">Order {{ order.name }}</h1>
    <p style="text-align:center;opacity:.65">Placed {{ order.created_at | date: '%b %d, %Y' }}</p>
    <p style="text-align:center"><a href="{{ routes.account_url }}">&larr; Back to account</a></p>

    <table class="size-table" style="text-align:left;margin-top:18px">
      <thead><tr><th>Item</th><th>Qty</th><th>Price</th></tr></thead>
      <tbody>
        {%- for line in order.line_items -%}
          <tr><td>{{ line.title }}</td><td>{{ line.quantity }}</td><td>{{ line.final_line_price | money }}</td></tr>
        {%- endfor -%}
      </tbody>
    </table>

    <div style="text-align:right;margin-top:16px">
      <p>Subtotal: {{ order.line_items_subtotal_price | money }}</p>
      <p>Shipping: {{ order.shipping_price | money }}</p>
      <p style="font-weight:700;font-size:1.1rem">Total: {{ order.total_price | money }}</p>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Order", "settings": [] }
{% endschema %}
