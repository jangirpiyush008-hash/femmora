<section class="section">
  <div class="page-width">
    <h1 style="text-align:center;margin-bottom:28px">{{ blog.title }}</h1>
    {%- paginate blog.articles by 12 -%}
      {%- if blog.articles.size > 0 -%}
        <div class="product-grid" style="grid-template-columns:repeat(auto-fill,minmax(280px,1fr))">
          {%- for article in blog.articles -%}
            <a class="pcard" href="{{ article.url }}">
              <div class="pcard__media" style="aspect-ratio:16/10">
                {%- if article.image -%}
                  <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title | escape }}" loading="lazy">
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag }}
                {%- endif -%}
              </div>
              <div>
                <small style="opacity:.6">{{ article.published_at | date: '%b %d, %Y' }}</small>
                <h3 class="pcard__title" style="margin-top:4px">{{ article.title }}</h3>
              </div>
            </a>
          {%- endfor -%}
        </div>
        {%- if paginate.pages > 1 -%}
          <nav class="pagination" aria-label="Pagination">
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>
              {%- else -%}<span class="{% if part.title == paginate.current_page %}current{% endif %}">{{ part.title }}</span>{%- endif -%}
            {%- endfor -%}
          </nav>
        {%- endif -%}
      {%- else -%}
        <div class="empty-state"><p>No posts yet — check back soon.</p></div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{ "name": "Blog", "settings": [] }
{% endschema %}
