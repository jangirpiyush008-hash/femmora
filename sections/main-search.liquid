<section class="section">
  <div class="page-width">
    <div style="text-align:center;max-width:560px;margin-inline:auto">
      <h1>{{ 'search.title' | t }}</h1>
      <form action="{{ routes.search_url }}" method="get" role="search" style="display:flex;gap:10px;margin-top:16px">
        <label class="visually-hidden" for="SearchInput">{{ 'search.title' | t }}</label>
        <input id="SearchInput" class="input" type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'search.placeholder' | t }}" style="flex:1">
        <button type="submit" class="btn btn--primary">{{ 'search.title' | t }}</button>
      </form>
    </div>

    {%- if search.performed -%}
      {%- if search.results.size > 0 -%}
        {%- paginate search.results by 24 -%}
          <p style="text-align:center;opacity:.65;margin-block:24px">{{ search.results_count }} results for "{{ search.terms }}"</p>
          <div class="product-grid">
            {%- for item in search.results -%}
              {%- if item.object_type == 'product' -%}
                {% render 'product-card', product: item %}
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- if paginate.pages > 1 -%}
            <nav class="pagination" aria-label="Pagination">
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>
                {%- else -%}<span class="{% if part.title == paginate.current_page %}current{% endif %}">{{ part.title }}</span>{%- endif -%}
              {%- endfor -%}
            </nav>
          {%- endif -%}
        {%- endpaginate -%}
      {%- else -%}
        <div class="empty-state"><p>{{ 'search.no_results' | t }}</p></div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Search", "settings": [] }
{% endschema %}
