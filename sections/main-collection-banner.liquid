{%- if collection.image and section.settings.show_image -%}
  <div class="coll-banner coll-banner--image">
    <div class="coll-banner__bg">
      <img src="{{ collection.image | image_url: width: 1800 }}" alt="{{ collection.title | escape }}" loading="eager">
    </div>
    <div class="coll-banner__content">
      <h1>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}<p>{{ collection.description | strip_html | truncate: 160 }}</p>{%- endif -%}
    </div>
  </div>
{%- else -%}
  <div class="coll-banner">
    <div class="coll-banner__content">
      <h1>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}<p>{{ collection.description | strip_html | truncate: 160 }}</p>{%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Collection banner",
  "settings": [
    { "type": "checkbox", "id": "show_image", "label": "Show collection image as banner", "default": true }
  ]
}
{% endschema %}
