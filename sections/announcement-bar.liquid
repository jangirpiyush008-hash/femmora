{%- if section.settings.enable -%}
  <div class="announcement" role="region" aria-label="Announcement">
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
    {%- else -%}
      {{ section.settings.text }}
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "checkbox", "id": "enable", "label": "Show announcement", "default": true },
    { "type": "text", "id": "text", "label": "Text", "default": "100% Prepaid • Free shipping over ₹999 • Pan-India delivery in 4–5 days" },
    { "type": "url", "id": "link", "label": "Link (optional)" }
  ]
}
{% endschema %}
