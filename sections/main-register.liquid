<section class="section">
  <div class="page-width" style="max-width:460px">
    <h1 style="text-align:center">{{ 'customer.register' | t }}</h1>
    {%- form 'create_customer' -%}
      {{ form.errors | default_errors }}
      <div class="field">
        <label for="RegFirst">First name</label>
        <input id="RegFirst" class="input" type="text" name="customer[first_name]" autocomplete="given-name">
      </div>
      <div class="field">
        <label for="RegLast">Last name</label>
        <input id="RegLast" class="input" type="text" name="customer[last_name]" autocomplete="family-name">
      </div>
      <div class="field">
        <label for="RegEmail">{{ 'customer.email' | t }}</label>
        <input id="RegEmail" class="input" type="email" name="customer[email]" autocomplete="email" required>
      </div>
      <div class="field">
        <label for="RegPassword">{{ 'customer.password' | t }}</label>
        <input id="RegPassword" class="input" type="password" name="customer[password]" autocomplete="new-password" required>
      </div>
      <button type="submit" class="btn btn--primary btn--full">{{ 'customer.register' | t }}</button>
    {%- endform -%}
    <p style="text-align:center;margin-top:22px">Already have an account? <a href="{{ routes.account_login_url }}"><strong>{{ 'customer.login' | t }}</strong></a></p>
  </div>
</section>

{% schema %}
{ "name": "Register", "settings": [] }
{% endschema %}
