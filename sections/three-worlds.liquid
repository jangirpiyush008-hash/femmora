<section class="section">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-head"><h2>{{ section.settings.heading }}</h2></div>
    {%- endif -%}
    <div class="worlds">
      {%- for block in section.blocks -%}
        {%- liquid
          case block.settings.accent
            when 'sage'
              assign accent = 'var(--color-accent-sage)'
            when 'gold'
              assign accent = 'var(--color-accent-gold)'
            else
              assign accent = 'var(--color-brand)'
          endcase
        -%}
        {%- assign wcoll = block.settings.collection -%}
        <div class="world" style="--world-accent: {{ accent }}" {{ block.shopify_attributes }}>
          <div class="world__media">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 800 }}"
                   alt="{{ block.settings.title | escape }}"
                   width="{{ block.settings.image.width }}"
                   height="{{ block.settings.image.height }}"
                   loading="lazy">
            {%- elsif wcoll.featured_image != blank -%}
              <img src="{{ wcoll.featured_image | image_url: width: 800 }}"
                   alt="{{ block.settings.title | escape }}" loading="lazy">
            {%- else -%}
              {{ 'collection-apparel-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          <div class="world__body">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
            <a href="{{ block.settings.link | default: routes.all_products_collection_url }}" class="btn btn--outline">{{ block.settings.button_label }}</a>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Three worlds",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop our worlds" }
  ],
  "blocks": [
    {
      "type": "world",
      "name": "World card",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection (image fallback)" },
        { "type": "image_picker", "id": "image", "label": "Image override" },
        { "type": "text", "id": "title", "label": "Title", "default": "Mom" },
        { "type": "text", "id": "text", "label": "Text", "default": "Feeding-friendly and maternity wear designed for comfort." },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
        { "type": "url", "id": "link", "label": "Link" },
        {
          "type": "select", "id": "accent", "label": "Accent colour", "default": "brand",
          "options": [
            { "value": "brand", "label": "Rosewood (brand)" },
            { "value": "sage", "label": "Sage (Mom)" },
            { "value": "gold", "label": "Gold (Jewellery)" }
          ]
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Three worlds",
      "blocks": [
        { "type": "world", "settings": { "title": "Mom", "text": "Maternity dresses, feeding wear and nursing bras designed for comfort.", "accent": "sage" } },
        { "type": "world", "settings": { "title": "Women", "text": "Kurtis and kurta sets — elegant ethnic wear for every day.", "accent": "brand" } },
        { "type": "world", "settings": { "title": "Jewellery", "text": "Silver earrings, necklaces, bangles and rings that go with everything.", "accent": "gold" } }
      ]
    }
  ]
}
{% endschema %}
