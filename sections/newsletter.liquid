<section class="section" style="background:color-mix(in srgb, var(--color-brand) 7%, var(--color-bg))">
  <div class="page-width">
    <div class="newsletter">
      <h2>{{ section.settings.heading }}</h2>
      <p style="opacity:.75">{{ section.settings.text }}</p>
      {%- form 'customer', class: 'newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {%- if form.posted_successfully? -%}
          <p>{{ 'newsletter.success' | t }}</p>
        {%- else -%}
          <label class="visually-hidden" for="NewsletterEmail">{{ 'newsletter.label' | t }}</label>
          <input id="NewsletterEmail" class="input" type="email" name="contact[email]" placeholder="{{ 'newsletter.label' | t }}" required>
          <button type="submit" class="btn btn--primary">{{ 'newsletter.button' | t }}</button>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join our list" },
    { "type": "text", "id": "text", "label": "Text", "default": "New drops, restocks and member-only offers." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
