<section class="section">
  <div class="page-width page-narrow">
    <h1 style="text-align:center">{{ page.title }}</h1>
    <div class="rte">
      {%- if page.content != blank -%}
        {{ page.content }}
      {%- else -%}
        {{ section.settings.content }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Policy page",
  "settings": [
    {
      "type": "richtext",
      "id": "content",
      "label": "Default content",
      "info": "Shown only while the page body in Shopify admin is empty. Write your own content on the page to replace it."
    }
  ]
}
{% endschema %}
