<section class="section">
  <div class="page-width" style="max-width:460px">
    <h1 style="text-align:center">Reset password</h1>
    {%- form 'reset_customer_password' -%}
      {{ form.errors | default_errors }}
      <div class="field">
        <label for="ResetPassword">New password</label>
        <input id="ResetPassword" class="input" type="password" name="customer[password]" autocomplete="new-password" required>
      </div>
      <div class="field">
        <label for="ResetPasswordConfirm">Confirm password</label>
        <input id="ResetPasswordConfirm" class="input" type="password" name="customer[password_confirmation]" autocomplete="new-password" required>
      </div>
      <button type="submit" class="btn btn--primary btn--full">Reset password</button>
    {%- endform -%}
  </div>
</section>

{% schema %}
{ "name": "Reset password", "settings": [] }
{% endschema %}
